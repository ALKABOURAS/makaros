<div class="page-body">
    <div class="lesson-header-card" style="justify-content: space-between; background-color: #1a1a1a;">
        <div>
            <h2>Τεστ: <span style="color: #64ffda;">{{chapter.title}}</span></h2>
            <p style="color: #888;">Ερώτηση {{progressNum}} από {{targetNum}}</p>
        </div>

        <!-- Ένδειξη Smart Algorithm (Μόνο για να βλέπουμε ότι δουλεύει!) -->
        <div style="background-color: #222; padding: 10px 15px; border-radius: 8px; border: 1px dashed #64ffda; text-align: center;">
            <span style="font-size: 0.8rem; color: #aaa;">Επίπεδο Αλγορίθμου</span><br>
            <strong class="diff-{{currentDifficulty}}" style="padding: 2px 8px; border-radius: 12px;">Δυσκολία {{currentDifficulty}} / 5</strong>
        </div>
    </div>

    <div class="chart-container" style="max-width: 700px; margin: 0 auto;">

        <form action="/lessons/{{lessonId}}/chapters/{{chapter.id}}/test" method="POST">

            <div class="question-block" style="background-color: #222; padding: 25px; border-radius: 12px; border-left: 4px solid #64ffda;">

                <h3 style="margin-top: 0; color: #efefef; font-size: 1.2rem; line-height: 1.5;">
                    {{question.question_text}}
                </h3>

                <div class="options-list" style="margin-top: 25px;">

                    {{#if (eq question.type "open_ended")}}
                        <!-- ΑΝΟΙΧΤΗ ΕΡΩΤΗΣΗ -->
                        <input type="text" name="answer" required autocomplete="off"
                               placeholder="Πληκτρολογήστε την απάντησή σας..."
                               style="width: 100%; padding: 15px; background: #1a1a1a; color: white; border: 1px solid #333; border-radius: 8px; font-size: 1.1rem;">


                    {{else}}
                        {{#if (eq question.type "fill_blanks")}}
                            <!-- ΣΥΜΠΛΗΡΩΣΗ ΚΕΝΩΝ -->
                            <p style="font-size: 1.2rem; line-height: 2; color: #ccc;">
                                <!-- Το τριπλό { } επιτρέπει στο Handlebars να κάνει render το HTML που φτιάξαμε στον controller! -->
                                {{{question.html_text}}}
                            </p>

                        {{else}}
                            <!-- ΠΟΛΛΑΠΛΗΣ & ΣΩΣΤΟ/ΛΑΘΟΣ (Radio Buttons) -->
                            <div style="display: flex; flex-direction: column; gap: 15px;">
                                {{#each question.parsedOptions}}
                                    <label style="display: flex; align-items: center; gap: 15px; background-color: #1a1a1a; padding: 15px; border-radius: 8px; cursor: pointer; border: 1px solid #333;">
                                        <input type="radio" name="answer" value="{{this}}" required style="accent-color: #64ffda; transform: scale(1.3);">
                                        <span style="color: #ccc; font-size: 1.05rem;">{{this}}</span>
                                    </label>
                                {{/each}}
                            </div>
                        {{/if}}
                    {{/if}}

                </div>

            </div>

            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 30px;">
                <a href="/lessons/{{lessonId}}/view" style="color: #ff5f5f; text-decoration: none; font-size: 0.9rem;">✖ Ακύρωση Τεστ</a>

                <button type="submit" class="submit-btn" style="background-color: #64ffda; color: #121212; padding: 15px 40px; font-size: 1.1rem; border-radius: 30px;">
                    Επόμενη Ερώτηση &rarr;
                </button>
            </div>
        </form>

    </div>
</div>

<style>
    label:hover { border-color: #64ffda !important; }
    /* Χρώματα δυσκολίας από το manage-lesson.css */
    .diff-1 { color: #8bc34a; }
    .diff-2 { color: #cddc39; }
    .diff-3 { color: #ffeb3b; }
    .diff-4 { color: #ff9800; }
    .diff-5 { color: #f44336; }
</style>