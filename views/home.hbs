<i data-lucide="home"></i>
<div class="dashboard-overview">
    <h2 class="section-title">Επισκόπηση: {{user.fullName}}</h2>

    <!-- 4 Στατιστικά Κουτάκια (Stats Grid) με δυναμικά δεδομένα! -->
    <div class="stats-grid">
        <div class="stat-card blue">
            <span class="stat-label">{{stats.card1.label}}</span>
            <div class="stat-main">
                <span class="stat-value">{{stats.card1.value}}</span>
                <span class="stat-percent">{{stats.card1.percent}}</span>
            </div>
        </div>

        <div class="stat-card pink">
            <span class="stat-label">{{stats.card2.label}}</span>
            <div class="stat-main">
                <span class="stat-value">{{stats.card2.value}}</span>
                <span class="stat-percent">{{stats.card2.percent}}</span>
            </div>
        </div>

        <div class="stat-card purple">
            <span class="stat-label">{{stats.card3.label}}</span>
            <div class="stat-main">
                <span class="stat-value">{{stats.card3.value}}</span>
                <span class="stat-percent">{{stats.card3.percent}}</span>
            </div>
        </div>

        <div class="stat-card yellow">
            <span class="stat-label">{{stats.card4.label}}</span>
            <div class="stat-main">
                <span class="stat-value">{{stats.card4.value}}</span>
                <span class="stat-percent positive">{{stats.card4.percent}}</span>
            </div>
        </div>
    </div>

    <!-- Filler Περιοχή για το Γράφημα (Εξέλιξη / Δραστηριότητα) -->
    <div class="chart-container main-chart">
        <div class="chart-header">
            {{#if (eq user.role "professor")}}
                <h3>Δραστηριότητα Φοιτητών στα Μαθήματά σας</h3>
            {{else}}
                <h3>Εξέλιξη Μέσου Όρου</h3>
            {{/if}}
        </div>
        <div class="chart-placeholder">
            <!-- Εδώ θα μπει το Chart.js αργότερα -->
            <img src="/img/chart-mockup.png" alt="Graph Mockup" style="width:100%; opacity: 0.6;">
        </div>
    </div>

    <!-- Κάτω Μέρος: Top Λίστα -->
    <div class="chart-container bottom-chart">
        {{#if (eq user.role "professor")}}
            <h3>Τα πιο δημοφιλή σας Μαθήματα</h3>
        {{else}}
            <h3>Κορυφαία Μαθήματα / Ασκήσεις</h3>
        {{/if}}

        <div class="bar-chart-mockup">
            <!-- Απλό CSS bar mockup για τώρα (Διατηρείται ως είχε) -->
            <div class="bar-item"><div class="bar" style="height: 80%; background: #c2c2f0;"></div><span>Σύγχρονα Οικ.</span></div>
            <div class="bar-item"><div class="bar" style="height: 60%; background: #b2f2bb;"></div><span>Οικ. Θεωρία</span></div>
            <div class="bar-item"><div class="bar" style="height: 90%; background: #d0bfff;"></div><span>Μακροοικονομικά</span></div>
        </div>
    </div>
</div>