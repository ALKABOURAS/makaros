<i data-lucide="home"></i>
<div class="dashboard-overview">
    <h2 class="section-title">Επισκόπηση</h2>

    <!-- 4 Στατιστικά Κουτάκια (Stats Grid) -->
    <div class="stats-grid">
        <div class="stat-card blue">
            <span class="stat-label">Επιλεγμένα Μαθήματα</span>
            <div class="stat-main">
                <span class="stat-value">14</span>
                <span class="stat-percent">40%</span>
            </div>
        </div>

        <div class="stat-card pink">
            <span class="stat-label">Ολοκληρωμένα</span>
            <div class="stat-main">
                <span class="stat-value">12</span>
                <span class="stat-percent">85.7%</span>
            </div>
        </div>

        <div class="stat-card purple">
            <span class="stat-label">Ασκήσεις</span>
            <div class="stat-main">
                <span class="stat-value">105</span>
                <span class="stat-percent">30%</span>
            </div>
        </div>

        <div class="stat-card yellow">
            <span class="stat-label">Βαθμός</span>
            <div class="stat-main">
                <span class="stat-value">9.81</span>
                <span class="stat-percent positive">+6.08% ↗</span>
            </div>
        </div>
    </div>

    <!-- Filler Περιοχή για το Γράφημα (Εξέλιξη Μ.Ο.) -->
    <div class="chart-container main-chart">
        <div class="chart-header">
            <h3>Εξέλιξη Μέσου Όρου</h3>
        </div>
        <div class="chart-placeholder">
            <!-- Εδώ θα μπει το Chart.js αργότερα -->
            <img src="/img/chart-mockup.png" alt="Graph Mockup" style="width:100%; opacity: 0.6;">
        </div>
    </div>

    <!-- Κάτω Μέρος: Κορυφαία Μαθήματα -->
    <div class="chart-container bottom-chart">
        <h3>Κορυφαία Μαθήματα / Ασκήσεις</h3>
        <div class="bar-chart-mockup">
            <!-- Απλό CSS bar mockup για τώρα -->
            <div class="bar-item"><div class="bar" style="height: 80%; background: #c2c2f0;"></div><span>Σύγχρονα Οικ.</span></div>
            <div class="bar-item"><div class="bar" style="height: 60%; background: #b2f2bb;"></div><span>Οικ. Θεωρία</span></div>
            <div class="bar-item"><div class="bar" style="height: 90%; background: #d0bfff;"></div><span>Μακροοικονομικά</span></div>
        </div>
    </div>
</div>