<div class="page-body">
    <div class="lesson-header-card" style="justify-content: flex-start; gap: 20px;">
        <a href="/lessons/manage/{{lessonId}}" class="submit-btn" style="width: auto; padding: 10px 15px; text-decoration: none; background-color: #333; color: #efefef;">&larr; Πίσω στη Διαχείριση</a>
        <div class="lesson-info">
            <h2>Επεξεργασία Ερώτησης</h2>
            <p class="lesson-desc">Διορθώστε την εκφώνηση ή το βάρος (δυσκολία) της ερώτησης.</p>
        </div>
    </div>

    <div class="chart-container" style="max-width: 600px; margin: 0 auto;">
        <form action="/lessons/manage/{{lessonId}}/chapters/{{chapterId}}/questions/{{question.id}}/edit" method="POST" class="custom-form">

            <div class="form-group">
                <label>Εκφώνηση Ερώτησης</label>
                <textarea name="question_text" rows="4" required>{{question.question_text}}</textarea>
            </div>

            <div class="form-group">
                <label>Δυσκολία (1-5)</label>
                <select name="difficulty" required>
                    <!-- Χρησιμοποιούμε τον Handlebars helper 'eq' για να προ-επιλέξουμε τη σωστή δυσκολία -->
                    <option value="1" {{#if (eq question.difficulty 1)}}selected{{/if}}>1 - Πολύ Εύκολη</option>
                    <option value="2" {{#if (eq question.difficulty 2)}}selected{{/if}}>2 - Εύκολη</option>
                    <option value="3" {{#if (eq question.difficulty 3)}}selected{{/if}}>3 - Μέτρια</option>
                    <option value="4" {{#if (eq question.difficulty 4)}}selected{{/if}}>4 - Δύσκολη</option>
                    <option value="5" {{#if (eq question.difficulty 5)}}selected{{/if}}>5 - Απαιτητική</option>
                </select>
            </div>

            <button type="submit" class="submit-btn" style="background-color: #a8b1ff;">Αποθήκευση Αλλαγών</button>
        </form>
    </div>
</div>